<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:GravadorMulti.Models"
        xmlns:local="clr-namespace:GravadorMulti"
        xmlns:conv="clr-namespace:GravadorMulti.Converters"
        xmlns:vm="clr-namespace:GravadorMulti.ViewModels"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="GravadorMulti.MainWindow"
        Title="Gravador Pro (Dark Studio)"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MainBackgroundBrush}"
        Foreground="{DynamicResource MainForegroundBrush}"
        x:DataType="vm:MainWindowViewModel"
        KeyDown="OnWindow_KeyDown"> 
    <Window.Resources>
        <conv:ProgressToPixelConverter x:Key="ProgressToPixelConverter"/>
        <conv:InverseProgressToPixelConverter x:Key="InverseProgressToPixelConverter"/>
        <conv:BoolToBrushConverter x:Key="BoolToBrushConverter"/>
        <conv:NullToEmptyPointsConverter x:Key="NullToEmptyPointsConverter"/>
        <conv:MathMultiplyConverter x:Key="MathMultiplyConverter"/>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button.action">
            <Setter Property="Background" Value="{DynamicResource ButtonPrimaryBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ButtonTextBrush}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.action:pointerover">
            <Setter Property="Background" Value="{DynamicResource ButtonPrimaryHoverBrush}"/>
        </Style>
        <Style Selector="Button.action:pressed">
            <Setter Property="Opacity" Value="0.8"/>
        </Style>

        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="{DynamicResource ButtonSecondaryBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource MainForegroundBrush}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.secondary:pointerover">
            <Setter Property="Background" Value="{DynamicResource ButtonSecondaryHoverBrush}"/>
        </Style>
        <Style Selector="Button.secondary:pressed">
            <Setter Property="Opacity" Value="0.8"/>
        </Style>

        <Style Selector="Button.big">
            <Setter Property="Width" Value="240"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,10"/>
        </Style>

        <Style Selector="ListBoxItem">
            <Setter Property="Background" Value="{DynamicResource ListItemBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="ListBoxItem:pointerover">
            <Setter Property="Background" Value="{DynamicResource ListItemHoverBrush}"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ListItemSelectedBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        
        <Style Selector="ListBox.tabs ListBoxItem">
            <Setter Property="Background" Value="{DynamicResource ListItemBackgroundBrush}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="2,0,2,0"/>
            <Setter Property="CornerRadius" Value="6 6 0 0"/>
        </Style>
        <Style Selector="ListBox.tabs ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ButtonPrimaryBrush}"/>
        </Style>
        <Style Selector="ListBox.tabs ListBoxItem TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MainForegroundBrush}"/>
        </Style>
        <Style Selector="ListBox.tabs ListBoxItem:selected TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ButtonTextBrush}"/>
        </Style>
        
        <Style Selector="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource TertiaryBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource MainForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Menu > MenuItem:pointerover /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="{DynamicResource ButtonPrimaryHoverBrush}"/>
        </Style>
        <Style Selector="Menu > MenuItem:pointerover /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="TextBlock.Foreground" Value="{DynamicResource ButtonTextBrush}"/>
        </Style>
        <Style Selector="MenuItem:pointerover /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="{DynamicResource ButtonPrimaryHoverBrush}"/>
        </Style>
        <Style Selector="MenuItem:pointerover /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="TextBlock.Foreground" Value="{DynamicResource ButtonTextBrush}"/>
        </Style>
    </Window.Styles>

    <DockPanel>
        <Menu DockPanel.Dock="Top" Background="{DynamicResource SecondaryBackgroundBrush}">
            <MenuItem Header="_Arquivo">
                <MenuItem Header="Novo Projeto" Click="BtnNovoProjeto_Click"/>
                <MenuItem Header="Abrir Projeto" Click="BtnCarregar_Click"/>
                <Separator/>
                <MenuItem Header="Sair" Click="MenuSair_Click"/>
            </MenuItem>
            <MenuItem Header="_Editar">
                <MenuItem Header="Desfazer" IsEnabled="False"/>
                <MenuItem Header="Refazer" IsEnabled="False"/>
            </MenuItem>
            <MenuItem Header="E_xibir">
                <MenuItem Header="Modo Claro" Click="MenuTemaClaro_Click"/>
                <MenuItem Header="Modo Escuro" Click="MenuTemaEscuro_Click"/>
            </MenuItem>
            <MenuItem Header="_Configurações">
                <MenuItem Header="Preferências" Click="MenuPreferencias_Click"/>
            </MenuItem>
            <MenuItem Header="A_juda">
                <MenuItem Header="Sobre" Click="MenuSobre_Click"/>
            </MenuItem>
        </Menu>
        
        <Grid> <!-- Main Application Content Area -->
        
        <Grid x:Name="ViewStart" IsVisible="{Binding !TemProjetosAbertos}" Background="{DynamicResource MainBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="15">
                <TextBlock Text="Gravador MultiTrack" FontSize="36" FontWeight="Bold" Foreground="{DynamicResource ButtonPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Gerenciador de Projetos" FontSize="18" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <Button Classes="big action" Click="BtnNovoProjeto_Click" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <PathIcon Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" Foreground="{DynamicResource ButtonTextBrush}" Width="18" Height="18"/>
                        <TextBlock Text="Novo Projeto" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="big secondary" Click="BtnCarregar_Click" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                        <PathIcon Data="M19,20H4C2.89,20 2,19.1 2,18V6C2,4.89 2.89,4 4,4H10L12,6H19A2,2 0 0,1 21,8H21L4,8V18L6.14,10H23.21L20.93,18.5C20.7,19.37 19.92,20 19,20Z" Foreground="{DynamicResource ButtonTextBrush}" Width="18" Height="18"/>
                        <TextBlock Text="Abrir Projeto" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Grid x:Name="ViewEditor" IsVisible="{Binding TemProjetosAbertos}" RowDefinitions="Auto, Auto, *, Auto">
            
            <Grid Grid.Row="0" Background="{DynamicResource QuaternaryBackgroundBrush}">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal" Margin="10,10,10,0">
                        <ListBox Classes="tabs" ItemsSource="{Binding ProjetosAbertos}" SelectedItem="{Binding ProjetoSelecionado}" Background="Transparent">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Nome}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                        <TextBlock Text="●" IsVisible="{Binding TemAlteracoesNaoSalvas}" Foreground="{DynamicResource AccentOrangeBrush}" FontSize="10" VerticalAlignment="Center"/>
                                        <Button Click="BtnFecharAba_Click" 
                                                Background="Transparent"
                                                Padding="5,2" CornerRadius="4" BorderThickness="0">
                                            <PathIcon Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" Foreground="{DynamicResource TextDimBrush}" Width="10" Height="10"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Button Click="BtnNovoProjeto_Click" Background="Transparent" Margin="5,0,0,5" VerticalAlignment="Bottom">
                            <PathIcon Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" Foreground="{DynamicResource TextMutedBrush}" Width="14" Height="14"/>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Border Grid.Row="1" Background="{DynamicResource SecondaryBackgroundBrush}" Padding="15,10">
                <Grid ColumnDefinitions="*, Auto">
                    <StackPanel Orientation="Vertical" Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ProjetoSelecionado.Nome}" FontWeight="Bold" FontSize="18" Foreground="{DynamicResource TextWhiteBrush}"/>
                        <TextBlock Text="{Binding ProjetoSelecionado.PastaRaiz}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Spacing="10" Grid.Column="1">
                        <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,20,0">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="M12,2A3,3 0 0,1 15,5V11A3,3 0 0,1 12,14A3,3 0 0,1 9,11V5A3,3 0 0,1 12,2M19,11C19,14.53 16.39,17.44 13,17.93V21H11V17.93C7.61,17.44 5,14.53 5,11H7A5,5 0 0,0 12,16A5,5 0 0,0 17,11H19Z" Foreground="{DynamicResource AccentBrush}" Width="16" Height="16" VerticalAlignment="Center"/>
                                <ComboBox ItemsSource="{Binding DispositivosEntrada}" 
                                          SelectedIndex="{Binding IndiceDispositivoSelecionado}"
                                          Width="200" Height="30" 
                                          Background="{DynamicResource TertiaryBackgroundBrush}" BorderThickness="0" CornerRadius="4"/>
                            </StackPanel>
                            
                            <ProgressBar Minimum="0" Maximum="1" 
                                         Value="{Binding NivelMicrofone}"
                                         Height="4" Width="225"
                                         Margin="0,5,0,0"
                                         Foreground="{DynamicResource AccentBrush}"
                                         Background="{DynamicResource ItemWaveBackgroundBrush}"
                                         CornerRadius="2"/>
                        </StackPanel>

                        <Button Click="BtnSalvar_Click" Classes="action" Background="{DynamicResource ButtonActionBrush}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="M15,9H5V5H15M12,19A3,3 0 0,1 9,16A3,3 0 0,1 12,13A3,3 0 0,1 15,16A3,3 0 0,1 12,19M17,3H5C3.89,3 3,3.9 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V7L17,3Z" Foreground="White" Width="14" Height="14"/>
                                <TextBlock Text="Salvar (Ctrl+S)" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Classes="secondary">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="M5,20H19V18H5M19,9H15V3H9V9H5L12,16L19,9Z" Foreground="White" Width="14" Height="14"/>
                                <TextBlock Text="Exportar" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuItem Header="Salvar como WAV (Original)" Click="BtnExportarWav_Click"/>
                                    <MenuItem Header="Salvar como MP3" Click="BtnExportarMp3_Click"/>
                                    <MenuItem Header="Salvar como AAC / M4A" Click="BtnExportarAac_Click"/>
                                    <MenuItem Header="Salvar como FLAC (Lossless)" Click="BtnExportarFlac_Click"/>
                                    <MenuItem Header="Salvar como OGG Vorbis" Click="BtnExportarOgg_Click"/>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="20" RowDefinitions="Auto, Auto, *" DataContext="{Binding ProjetoSelecionado}">
                <TextBlock Text="Roteiro:" Foreground="{DynamicResource TextDimBrush}" Margin="0,0,0,8"/>
                
                <TextBox Grid.Row="1" Height="120" TextWrapping="Wrap" 
                         AcceptsReturn="True" 
                         Watermark="Cole seu texto aqui..."
                         Background="{DynamicResource SecondaryBackgroundBrush}" Foreground="{DynamicResource TextWhiteBrush}" BorderThickness="0" CornerRadius="8"
                         Padding="10"
                         Text="{Binding TextoRoteiro}"/>

                <Grid Grid.Row="2" RowDefinitions="Auto, *" Margin="0,20,0,0">
                    <Button Grid.Row="0" Classes="action"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Click="BtnFatiar_Click" Margin="0,0,0,15">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="M19,3L13,9L15,11L22,4V3M12,12.5A0.5,0.5 0 0,1 11.5,12A0.5,0.5 0 0,1 12,11.5A0.5,0.5 0 0,1 12.5,12A0.5,0.5 0 0,1 12,12.5M6,20A2,2 0 0,1 4,18C4,16.89 4.9,16 6,16A2,2 0 0,1 8,18C8,19.11 7.1,20 6,20M6,8A2,2 0 0,1 4,6C4,4.89 4.9,4 6,4A2,2 0 0,1 8,6C8,7.11 7.1,8 6,8M9.64,7.64C9.87,7.14 10,6.59 10,6A4,4 0 0,0 6,2A4,4 0 0,0 2,6A4,4 0 0,0 6,10C6.59,10 7.14,9.87 7.64,9.64L10,12L7.64,14.36C7.14,14.13 6.59,14 6,14A4,4 0 0,0 2,18A4,4 0 0,0 6,22A4,4 0 0,0 10,18C10,17.41 9.87,16.86 9.64,16.36L12,14L19,21H22V20L9.64,7.64Z" Foreground="White" Width="16" Height="16"/>
                            <TextBlock Text="Fatiar Texto" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <ListBox Grid.Row="1" ItemsSource="{Binding Itens}" Background="Transparent" 
                             SelectionChanged="OnListBox_SelectionChanged"
                             x:Name="ItensListBox">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <!-- Evita overlays/bugs ao redimensionar abas em tempo real via UI virtualizada nativa -->
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:ItemRoteiro">
                                <Border Background="Transparent" Margin="0,2">
                                    
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="↑ Mover para Cima" Click="BtnMoverCima_Click" CommandParameter="{Binding}"/>
                                            <MenuItem Header="↓ Mover para Baixo" Click="BtnMoverBaixo_Click" CommandParameter="{Binding}"/>
                                            <Separator/>
                                            <MenuItem Header="✂ Modo de Corte" Click="BtnModoRecorte_Click" CommandParameter="{Binding}" IsVisible="{Binding TemAudio}"/>
                                            <MenuItem Header="✂ Remover Silêncios" Click="BtnAbrirCorteSilencio_Click" CommandParameter="{Binding}" IsVisible="{Binding TemAudio}"/>
                                            <MenuItem Header="✕ Excluir Frase" Click="BtnExcluirItem_Click" CommandParameter="{Binding}"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>

                                    <StackPanel Spacing="5">
                                        <Grid ColumnDefinitions="Auto, *, Auto" Tapped="OnItemTapped" Cursor="Hand" Background="Transparent">
                                            
                                            <!-- Handle de Arrastar e Soltar -->
                                            <Border Grid.Column="0" Width="30" Background="Transparent" 
                                                    Cursor="SizeAll" 
                                                    PointerPressed="OnDragHandlePointerPressed"
                                                    PointerMoved="OnDragHandlePointerMoved"
                                                    PointerReleased="OnDragHandlePointerReleased"
                                                    ToolTip.Tip="Arraste para reordenar"
                                                    VerticalAlignment="Stretch">
                                                <PathIcon Data="M7,19V17H9V19H7M11,19V17H13V19H11M15,19V17H17V19H15M7,15V13H9V15H7M11,15V13H13V15H11M15,15V13H17V15H15M7,11V9H9V11H7M11,11V9H13V11H11M15,11V9H17V11H15M7,7V5H9V7H7M11,7V5H13V7H11M15,7V5H17V7H15Z" 
                                                          Foreground="{DynamicResource TextSemiDimBrush}" Width="14" Height="14" VerticalAlignment="Center" Margin="5,0"/>
                                            </Border>

                                            <TextBlock Grid.Column="1" Text="{Binding Texto}" VerticalAlignment="Center" TextWrapping="Wrap" FontSize="15" Margin="5"/>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                                                
                                                <Button Click="BtnLimparAudio_Click" 
                                                        Background="Transparent" 
                                                        Padding="10,5"
                                                        BorderThickness="0"
                                                        IsVisible="{Binding TemAudio}"
                                                        ToolTip.Tip="Limpar Áudio (Delete)">
                                                    <PathIcon Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" Foreground="{DynamicResource TextDimBrush}" Width="14" Height="14"/>
                                                </Button>

                                                <Button Click="BtnGravar_Click" Classes="secondary"
                                                        Background="{Binding IsRecording, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#FF4444:Transparent'}">
                                                    <PathIcon Data="M12,2A3,3 0 0,1 15,5V11A3,3 0 0,1 12,14A3,3 0 0,1 9,11V5A3,3 0 0,1 12,2M19,11C19,14.53 16.39,17.44 13,17.93V21H11V17.93C7.61,17.44 5,14.53 5,11H7A5,5 0 0,0 12,16A5,5 0 0,0 17,11H19Z" Foreground="White" Width="14" Height="14"/>
                                                </Button>
                                                <Button Click="BtnStop_Click" 
                                                        Classes="secondary" 
                                                        IsVisible="{Binding TemAudio}"
                                                        ToolTip.Tip="Parar e Voltar ao Início">
                                                    <PathIcon Data="M18,18H6V6H18V18Z" Foreground="White" Width="14" Height="14"/>
                                                </Button>

                                                <Button x:Name="PlayPauseButton" 
                                                        Click="BtnPlay_Click" 
                                                        Classes="secondary" 
                                                        IsEnabled="{Binding TemAudio}"
                                                        ToolTip.Tip="Reproduzir / Pausar">
                                                    <PathIcon Data="M8,5.14V19.14L19,12.14L8,5.14Z" Foreground="White" Width="14" Height="14"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>

                                        <Border Background="{DynamicResource ItemWaveBackgroundBrush}" CornerRadius="6" Padding="10" IsVisible="{Binding IsExpanded}" Height="100">
                                            <Grid>
                                                <TextBlock Text="Sem áudio gravado" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" IsVisible="{Binding !TemAudio}"/>

                                                <ScrollViewer x:Name="WaveScroll" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" IsVisible="{Binding TemAudio}">
                                                    <Grid x:Name="WaveGrid" VerticalAlignment="Stretch" HorizontalAlignment="Left" Background="Transparent"
                                                          PointerWheelChanged="WaveGrid_PointerWheelChanged"
                                                          PointerPressed="Waveform_PointerPressed" PointerMoved="Waveform_PointerMoved" PointerReleased="Waveform_PointerReleased">
                                                        <Grid.Width>
                                                            <MultiBinding Converter="{StaticResource MathMultiplyConverter}">
                                                                <Binding Path="Bounds.Width" ElementName="WaveScroll" />
                                                                <Binding Path="ZoomLevel" />
                                                            </MultiBinding>
                                                        </Grid.Width>
                                                    <Border BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,0,0,1" VerticalAlignment="Center" IsHitTestVisible="False"/>
                                                    <Polygon Points="{Binding WaveformPoints, Converter={StaticResource NullToEmptyPointsConverter}}" Fill="{DynamicResource AccentBrush}" Stretch="Fill" Opacity="0.8" IsHitTestVisible="False"/>
                                                    <Canvas HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                                        <!-- Área Selecionada em Destaque -->
                                                        <Border Background="{DynamicResource ButtonTransparentHover}" BorderBrush="{DynamicResource AccentOrangeBrush}" BorderThickness="2,0" IsVisible="{Binding IsCroppingMode}" IsHitTestVisible="False" Height="80">
                                                            <Canvas.Left>
                                                                <MultiBinding Converter="{StaticResource ProgressToPixelConverter}">
                                                                    <Binding Path="SelectionStartProgress"/>
                                                                    <Binding ElementName="WaveGrid" Path="Bounds.Width"/>
                                                                </MultiBinding>
                                                            </Canvas.Left>
                                                            <Border.Width>
                                                                <MultiBinding Converter="{StaticResource ProgressToPixelConverter}">
                                                                    <Binding Path="SelectionEndProgress" />
                                                                    <Binding ElementName="WaveGrid" Path="Bounds.Width"/>
                                                                    <Binding Path="SelectionStartProgress" />
                                                                </MultiBinding>
                                                            </Border.Width>
                                                        </Border>
                                                        
                                                        <!-- Área escura fora da seleção (Esquerda) -->
                                                        <Border Background="{DynamicResource OverlayBackgroundBrush}" IsVisible="{Binding IsCroppingMode}" IsHitTestVisible="False" Height="80" HorizontalAlignment="Left">
                                                            <Border.Width>
                                                                <MultiBinding Converter="{StaticResource ProgressToPixelConverter}">
                                                                    <Binding Path="SelectionStartProgress"/>
                                                                    <Binding ElementName="WaveGrid" Path="Bounds.Width"/>
                                                                </MultiBinding>
                                                            </Border.Width>
                                                        </Border>

                                                        <!-- Área escura fora da seleção (Direita) -->
                                                        <Border Background="{DynamicResource OverlayBackgroundBrush}" IsVisible="{Binding IsCroppingMode}" IsHitTestVisible="False" Height="80" HorizontalAlignment="Right">
                                                            <Border.Width>
                                                                <MultiBinding Converter="{StaticResource InverseProgressToPixelConverter}">
                                                                    <Binding Path="SelectionEndProgress"/>
                                                                    <Binding ElementName="WaveGrid" Path="Bounds.Width"/>
                                                                </MultiBinding>
                                                            </Border.Width>
                                                        </Border>

                                                        <!-- Puxador Esquerdo -->
                                                        <Border Width="24" Height="80" Background="Transparent" IsVisible="{Binding IsCroppingMode}" IsHitTestVisible="False" Margin="-12,0,0,0">
                                                            <Canvas.Left>
                                                                <MultiBinding Converter="{StaticResource ProgressToPixelConverter}">
                                                                    <Binding Path="SelectionStartProgress"/>
                                                                    <Binding ElementName="WaveGrid" Path="Bounds.Width"/>
                                                                </MultiBinding>
                                                            </Canvas.Left>
                                                            <Border Width="8" Height="80" Background="{DynamicResource AccentOrangeBrush}" CornerRadius="4" HorizontalAlignment="Center" VerticalAlignment="Center" BoxShadow="0 2 5 0 #88000000">
                                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="1">
                                                                    <Border Width="1" Height="20" Background="{DynamicResource SecondaryForegroundBrush}"/>
                                                                    <Border Width="1" Height="20" Background="{DynamicResource SecondaryForegroundBrush}"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </Border>

                                                        <!-- Puxador Direito -->
                                                        <Border Width="24" Height="80" Background="Transparent" IsVisible="{Binding IsCroppingMode}" IsHitTestVisible="False" Margin="-12,0,0,0">
                                                            <Canvas.Left>
                                                                <MultiBinding Converter="{StaticResource ProgressToPixelConverter}">
                                                                    <Binding Path="SelectionEndProgress"/>
                                                                    <Binding ElementName="WaveGrid" Path="Bounds.Width"/>
                                                                </MultiBinding>
                                                            </Canvas.Left>
                                                            <Border Width="8" Height="80" Background="{DynamicResource AccentOrangeBrush}" CornerRadius="4" HorizontalAlignment="Center" VerticalAlignment="Center" BoxShadow="0 2 5 0 #88000000">
                                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="1">
                                                                    <Border Width="1" Height="20" Background="{DynamicResource SecondaryForegroundBrush}"/>
                                                                    <Border Width="1" Height="20" Background="{DynamicResource SecondaryForegroundBrush}"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </Border>
                                                        <Border Width="2" Height="80" Background="{DynamicResource WaveProgressBrush}" IsVisible="{Binding TemAudio}" IsHitTestVisible="False">
                                                            <Border.IsVisible>
                                                                <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                                    <Binding Path="TemAudio"/>
                                                                    <Binding Path="!IsCroppingMode"/>
                                                                </MultiBinding>
                                                            </Border.IsVisible>
                                                            <Canvas.Left>
                                                                <MultiBinding Converter="{StaticResource ProgressToPixelConverter}">
                                                                    <Binding Path="PlaybackProgress"/>
                                                                    <Binding ElementName="WaveGrid" Path="Bounds.Width"/>
                                                                </MultiBinding>
                                                            </Canvas.Left>
                                                        </Border>
                                                    </Canvas>
                                                </Grid>
                                            </ScrollViewer>
                                        </Grid>
                                    </Border>
                                    
                                    <!-- OVERLAYS E CONTROLES DE ZOOM / CORTE -->
                                    <StackPanel Grid.Row="2" Orientation="Vertical" ClipToBounds="True">
                                        <StackPanel.Styles>
                                            <Style Selector="StackPanel.showCrop">
                                                <Setter Property="MaxHeight" Value="85"/>
                                                <Setter Property="Opacity" Value="1"/>
                                                <Setter Property="Margin" Value="0,10,0,0"/>
                                            </Style>
                                            <Style Selector="StackPanel.hideCrop">
                                                <Setter Property="MaxHeight" Value="0"/>
                                                <Setter Property="Opacity" Value="0"/>
                                                <Setter Property="Margin" Value="0,-20,0,0"/>
                                            </Style>
                                        </StackPanel.Styles>
                                        
                                        <StackPanel Classes.showCrop="{Binding IsCroppingMode}" Classes.hideCrop="{Binding !IsCroppingMode}">
                                            <StackPanel.Transitions>
                                                <Transitions>
                                                    <DoubleTransition Property="MaxHeight" Duration="0:0:0.2" Easing="SineEaseOut"/>
                                                    <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="SineEaseOut"/>
                                                    <ThicknessTransition Property="Margin" Duration="0:0:0.2" Easing="SineEaseOut"/>
                                                </Transitions>
                                            </StackPanel.Transitions>

                                            <!-- The buttons -->
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                                                <Button Click="BtnConfirmarCorte_Click" Background="{DynamicResource ButtonActionBrush}" Foreground="{DynamicResource ButtonTextBrush}" Padding="10,5" CornerRadius="15" FontSize="12">
                                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                                        <PathIcon Data="M21,7L9,19L3.5,13.5L4.91,12.09L9,16.17L19.59,5.59L21,7Z" Foreground="White" Width="12" Height="12"/>
                                                        <TextBlock Text="Confirmar Corte" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Click="BtnCancelarCorte_Click" Background="{DynamicResource ButtonDangerBrush}" Foreground="{DynamicResource ButtonTextBrush}" Padding="10,5" CornerRadius="15" FontSize="12">
                                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                                        <PathIcon Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" Foreground="White" Width="12" Height="12"/>
                                                        <TextBlock Text="Cancelar" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                            
                                            <!-- Zoom Slider -->
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10" Margin="0,15,0,0">
                                                <TextBlock Text="Zoom:" VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                                                <Slider Minimum="1" Maximum="10" Value="{Binding ZoomLevel}" Width="150" 
                                                        TickFrequency="1" IsSnapToTickEnabled="False"/>
                                                <TextBlock Text="{Binding ZoomLevel, StringFormat='x{0:F1}'}" VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Width="30"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                    <!-- Fim dos controles extras de crop -->
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>

            <Border Grid.Row="3" Background="{DynamicResource PanelBackgroundBrush}" Padding="10,5">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Status:" Foreground="{DynamicResource TextMutedBrush}"/>
                    <TextBlock Text="{Binding ProjetoSelecionado.StatusTexto}" Margin="8,0" Foreground="{DynamicResource ButtonPrimaryBrush}" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="OverlayFatiar" IsVisible="False" Background="{DynamicResource OverlayBackgroundBrush}">
            <Border Width="400" VerticalAlignment="Center" HorizontalAlignment="Center" Background="{DynamicResource TertiaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="25">
                <StackPanel Spacing="20">
                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                        <PathIcon Data="M13,14H11V10H13M13,18H11V16H13M1,21H23L12,2L1,21Z" Foreground="{DynamicResource AccentOrangeBrush}" Width="22" Height="22"/>
                        <TextBlock Text="Atenção" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextLightBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtMsgFatiar" Text="" TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource TextSemiDimBrush}" FontSize="14"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15">
                        <Button Content="Cancelar" Click="BtnCancelarFatia_Click" Classes="secondary"/>
                        <Button Content="Confirmar e Apagar" Click="BtnConfirmarFatia_Click" Classes="action" Background="{DynamicResource ButtonDangerBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="OverlayFechar" IsVisible="False" Background="{DynamicResource OverlayBackgroundBrush}">
            <Border Width="450" VerticalAlignment="Center" HorizontalAlignment="Center" Background="{DynamicResource TertiaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="25">
                <StackPanel Spacing="20">
                    <TextBlock Text="Salvar alterações?" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextWhiteBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Você tem alterações não salvas neste projeto." TextAlignment="Center" Foreground="{DynamicResource TextSemiDimBrush}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15">
                        <Button Click="BtnSalvarFechar_Click" Classes="action" Background="{DynamicResource ButtonActionBrush}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="M15,9H5V5H15M12,19A3,3 0 0,1 9,16A3,3 0 0,1 12,13A3,3 0 0,1 15,16A3,3 0 0,1 12,19M17,3H5C3.89,3 3,3.9 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V7L17,3Z" Foreground="White" Width="14" Height="14"/>
                                <TextBlock Text="Salvar e Sair" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Content="Sair sem Salvar" Click="BtnNaoSalvarFechar_Click" Classes="secondary"/>
                        <Button Content="Cancelar" Click="BtnCancelarFechar_Click" Background="Transparent" Foreground="{DynamicResource TextDimBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Drag & Drop Visual Feedback -->
        <Canvas x:Name="DragOverlayCanvas" IsVisible="False" IsHitTestVisible="False">
            <Border x:Name="DragGhost" 
                    Background="{DynamicResource DragOverlayBackgroundBrush}" 
                    BorderBrush="{DynamicResource DragOverlayBorderBrush}" 
                    BorderThickness="2" 
                    CornerRadius="8" 
                    Padding="15,10"
                    BoxShadow="0 4 16 0 #88000000">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <PathIcon Data="M7,19V17H9V19H7M11,19V17H13V19H11M15,19V17H17V19H15M7,15V13H9V15H7M11,15V13H13V15H11M15,15V13H17V15H15M7,11V9H9V11H7M11,11V9H13V11H11M15,11V9H17V11H15M7,7V5H9V7H7M11,7V5H13V7H11M15,7V5H17V7H15Z" 
                              Foreground="{DynamicResource ButtonPrimaryBrush}" Width="14" Height="14"/>
                    <TextBlock x:Name="DragGhostText" 
                               Foreground="{DynamicResource MainForegroundBrush}" 
                               FontSize="14" 
                               MaxWidth="400" 
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>
            <Border x:Name="DropIndicatorLine" 
                    Background="{DynamicResource ButtonPrimaryBrush}" 
                    Height="3" 
                    CornerRadius="2" 
                    IsVisible="False"/>
        </Canvas>

        <!-- Overlay de Remoção de Silêncios Dinâmica -->
        <Grid x:Name="OverlaySilencios" IsVisible="False" Background="{DynamicResource OverlayBackgroundBrush}">
            <Border Width="700" VerticalAlignment="Center" HorizontalAlignment="Center" Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="20">
                <StackPanel Spacing="15">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <PathIcon Data="M3,9V15H7L12,20V4L7,9H3M16.5,12C16.5,10.23 15.48,8.71 14,7.97V16.02C15.48,15.29 16.5,13.77 16.5,12M14,3.23V5.29C16.89,6.15 19,8.83 19,12C19,15.17 16.89,17.85 14,18.71V20.77C18.01,19.86 21,16.28 21,12C21,7.72 18.01,4.14 14,3.23Z" Foreground="{DynamicResource ButtonPrimaryBrush}" Width="20" Height="20"/>
                        <TextBlock Text="Remover Silêncios" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextWhiteBrush}"/>
                    </StackPanel>

                    <!-- Painel de Parâmetros -->
                    <Border Background="{DynamicResource TertiaryBackgroundBrush}" CornerRadius="8" Padding="15">
                        <StackPanel Spacing="15">
                            <Grid ColumnDefinitions="*, 60">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Duração Mínima do Silêncio" Foreground="{DynamicResource TextLightBrush}" FontWeight="SemiBold"/>
                                    <TextBlock Text="Tempo contínuo abaixo do limite para ser cortado." FontSize="11" Foreground="{DynamicResource TextDimBrush}"/>
                                    <Slider x:Name="SliderDuracaoSilencio" Minimum="0.1" Maximum="3.0" Value="1.0" Foreground="{DynamicResource ButtonPrimaryBrush}" Margin="0,5,0,0"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding ElementName=SliderDuracaoSilencio, Path=Value, StringFormat={}{0:0.0}s}" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid ColumnDefinitions="*, 60">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Limite de Volume para Corte (dB)" Foreground="{DynamicResource TextLightBrush}" FontWeight="SemiBold"/>
                                    <TextBlock Text="Sons mais silenciosos que esse valor são ignorados." FontSize="11" Foreground="{DynamicResource TextDimBrush}"/>
                                    <Slider x:Name="SliderThresholdSilencio" Minimum="-80" Maximum="-20" Value="-45" Foreground="{DynamicResource ButtonPrimaryBrush}" Margin="0,5,0,0" SmallChange="1" LargeChange="5" IsSnapToTickEnabled="True" TickFrequency="1"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding ElementName=SliderThresholdSilencio, Path=Value, StringFormat={}{0:0}dB}" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Painel Comparativo (Original e Preview) -->
                    <Grid RowDefinitions="Auto, Auto" Margin="0,10,0,0">
                        <!-- Original -->
                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <StackPanel Spacing="5">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Áudio Original" Foreground="{DynamicResource TextWhiteBrush}" FontWeight="Bold"/>
                                    <TextBlock x:Name="InfoOriginalSilencio" Text="(0.0s)" Foreground="{DynamicResource TextDimBrush}"/>
                                </StackPanel>
                                <Border Background="{DynamicResource ItemWaveBackgroundBrush}" CornerRadius="6" Height="60">
                                    <Grid x:Name="WaveGridSilencioOriginal">
                                        <Border BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,0,0,1" VerticalAlignment="Center" IsHitTestVisible="False"/>
                                        <Polygon x:Name="PolyOriginalSilencio" Fill="{DynamicResource TextSemiDimBrush}" Stretch="Fill" Opacity="0.8" IsHitTestVisible="False"/>
                                        <Border x:Name="CursorOriginalSilencio" Width="2" Height="60" Background="{DynamicResource WaveProgressBrush}" HorizontalAlignment="Left" IsVisible="False"/>
                                    </Grid>
                                </Border>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Button x:Name="BtnPlayOriginalSilencio" Click="BtnPlayOriginalSilencio_Click" Background="Transparent" Foreground="{DynamicResource AccentBrush}" Padding="5">
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <PathIcon Data="M8,5.14V19.14L19,12.14L8,5.14Z" Width="12" Height="12"/>
                                            <TextBlock Text="Tocar Original"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="BtnStopOriginalSilencio" Click="BtnStopOriginalSilencio_Click" Background="Transparent" Foreground="{DynamicResource ButtonStopBrush}" Padding="5">
                                        <PathIcon Data="M18,18H6V6H18V18Z" Width="12" Height="12"/>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <!-- Preview -->
                        <Grid Grid.Row="1">
                            <StackPanel Spacing="5">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Prévia (Após Remoção)" Foreground="{DynamicResource TextWhiteBrush}" FontWeight="Bold"/>
                                    <TextBlock x:Name="InfoPreviewSilencio" Text="(Nenhum preview gerado)" Foreground="{DynamicResource AccentBrush}"/>
                                </StackPanel>
                                <Border Background="{DynamicResource ItemWaveBackgroundBrush}" CornerRadius="6" Height="60">
                                    <Grid x:Name="WaveGridSilencioPreview">
                                        <Border BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,0,0,1" VerticalAlignment="Center" IsHitTestVisible="False"/>
                                        <!-- Note: using another property for the generated points, managed in code behind -->
                                        <Polygon x:Name="PolyPreviewSilencio" Fill="{DynamicResource AccentBrush}" Stretch="Fill" Opacity="0.8" IsHitTestVisible="False"/>
                                        <Border x:Name="CursorPreviewSilencio" Width="2" Height="60" Background="{DynamicResource WaveProgressBrush}" HorizontalAlignment="Left" IsVisible="False"/>
                                    </Grid>
                                </Border>
                                <Grid ColumnDefinitions="*, Auto">
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                                        <Button x:Name="BtnPlayPreviewSilencio" Click="BtnPlayPreviewSilencio_Click" Background="Transparent" Foreground="{DynamicResource AccentBrush}" Padding="5" IsEnabled="False">
                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                <PathIcon Data="M8,5.14V19.14L19,12.14L8,5.14Z" Width="12" Height="12"/>
                                                <TextBlock Text="Tocar Prévia"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="BtnStopPreviewSilencio" Click="BtnStopPreviewSilencio_Click" Background="Transparent" Foreground="{DynamicResource ButtonStopBrush}" Padding="5" IsEnabled="False">
                                            <PathIcon Data="M18,18H6V6H18V18Z" Width="12" Height="12"/>
                                        </Button>
                                    </StackPanel>
                                    
                                    <!-- Ação central de Reprocessar -->
                                    <Button Grid.Column="1" Content="↻ Gerar Preview do Corte" Click="BtnGerarPreviewSilencio_Click" Classes="action" Background="{DynamicResource ButtonPrimaryBrush}" Padding="15,5"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <Separator Background="{DynamicResource BorderLightBrush}"/>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="15">
                        <TextBlock x:Name="StatusProcessamentoSilencio" VerticalAlignment="Center" Foreground="{DynamicResource TextDimBrush}" Margin="0,0,10,0"/>
                        <Button Content="Cancelar" Click="BtnCancelarSilencio_Click" Classes="secondary"/>
                        <Button Content="Aplicar Modificações" Click="BtnConfirmarSilencio_Click" Classes="action" Background="{DynamicResource ButtonActionBrush}" x:Name="BtnConfirmarSilencio" IsEnabled="False"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Overlay: Sobre o Aplicativo -->
        <Grid x:Name="OverlaySobre" IsVisible="False" Background="{DynamicResource OverlayBackgroundBrush}">
            <Border Width="420" VerticalAlignment="Center" HorizontalAlignment="Center" Background="{DynamicResource TertiaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="30">
                <StackPanel Spacing="18">
                    <TextBlock Text="Gravador MultiTrack" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource ButtonPrimaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Versão 1.0.0" FontSize="14" Foreground="{DynamicResource TextDimBrush}" HorizontalAlignment="Center"/>
                    <Separator Background="{DynamicResource BorderLightBrush}"/>
                    <StackPanel Spacing="8">
                        <TextBlock Text="Criado por" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Davi Andrei" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextWhiteBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Repositório" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="github.com/DaviAndreiDev/GravadorMulti" FontSize="13" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" Cursor="Hand" TextDecorations="Underline"/>
                    </StackPanel>
                    <Separator Background="{DynamicResource BorderLightBrush}"/>
                    <TextBlock Text="Aplicação de gravação multitrack feita com Avalonia UI e .NET." TextWrapping="Wrap" TextAlignment="Center" FontSize="12" Foreground="{DynamicResource TextSemiDimBrush}"/>
                    <Button Content="Fechar" Click="BtnFecharSobre_Click" Classes="secondary" HorizontalAlignment="Center" Padding="30,8"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Overlay: Preferências / Configurações -->
        <Grid x:Name="OverlayPreferencias" IsVisible="False" Background="{DynamicResource OverlayBackgroundBrush}">
            <Border Width="500" VerticalAlignment="Center" HorizontalAlignment="Center" Background="{DynamicResource TertiaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="30">
                <StackPanel Spacing="18">
                    <TextBlock Text="Preferências" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextWhiteBrush}" HorizontalAlignment="Center"/>
                    <Separator Background="{DynamicResource BorderLightBrush}"/>

                    <!-- Seção: Aparência -->
                    <StackPanel Spacing="10">
                        <TextBlock Text="Aparência" FontWeight="Bold" Foreground="{DynamicResource TextLightBrush}"/>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="Tema:" VerticalAlignment="Center" Foreground="{DynamicResource TextSemiDimBrush}"/>
                            <Button Content="☀ Claro" Click="MenuTemaClaro_Click" Classes="secondary" Padding="12,6"/>
                            <Button Content="🌙 Escuro" Click="MenuTemaEscuro_Click" Classes="secondary" Padding="12,6"/>
                        </StackPanel>
                    </StackPanel>

                    <Separator Background="{DynamicResource BorderLightBrush}"/>

                    <!-- Seção: Áudio -->
                    <StackPanel Spacing="10">
                        <TextBlock Text="Áudio" FontWeight="Bold" Foreground="{DynamicResource TextLightBrush}"/>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Dispositivo de entrada padrão" FontSize="12" Foreground="{DynamicResource TextDimBrush}"/>
                            <ComboBox ItemsSource="{Binding DispositivosEntrada}" SelectedIndex="{Binding IndiceDispositivoSelecionado}" Width="380" Background="{DynamicResource SecondaryBackgroundBrush}" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" CornerRadius="6"/>
                        </StackPanel>
                    </StackPanel>

                    <Separator Background="{DynamicResource BorderLightBrush}"/>

                    <!-- Seção: Projeto -->
                    <StackPanel Spacing="10">
                        <TextBlock Text="Projeto" FontWeight="Bold" Foreground="{DynamicResource TextLightBrush}"/>
                        <TextBlock Text="Configurações específicas do projeto estarão disponíveis em breve." FontSize="12" Foreground="{DynamicResource TextDimBrush}" TextWrapping="Wrap"/>
                    </StackPanel>

                    <Separator Background="{DynamicResource BorderLightBrush}"/>
                    <Button Content="Fechar" Click="BtnFecharPreferencias_Click" Classes="secondary" HorizontalAlignment="Center" Padding="30,8"/>
                </StackPanel>
            </Border>
        </Grid>

        </Grid> <!-- Main Application Content Area -->
    </DockPanel>
</Window>