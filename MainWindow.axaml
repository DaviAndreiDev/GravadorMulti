<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:GravadorMulti.Models"
        xmlns:local="clr-namespace:GravadorMulti"
        xmlns:conv="clr-namespace:GravadorMulti.Converters"
        xmlns:vm="clr-namespace:GravadorMulti.ViewModels"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="GravadorMulti.MainWindow"
        Title="Gravador Pro (Dark Studio)"
        WindowStartupLocation="CenterScreen"
        Background="#121212"
        Foreground="#E0E0E0"
        x:DataType="vm:MainWindowViewModel"
        KeyDown="OnWindow_KeyDown"> 
    <Window.Resources>
        <conv:ProgressToPixelConverter x:Key="ProgressToPixelConverter"/>
        <conv:InverseProgressToPixelConverter x:Key="InverseProgressToPixelConverter"/>
        <conv:BoolToBrushConverter x:Key="BoolToBrushConverter"/>
        <conv:NullToEmptyPointsConverter x:Key="NullToEmptyPointsConverter"/>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button.action">
            <Setter Property="Background" Value="#2D63C8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.action:pointerover">
            <Setter Property="Background" Value="#3A75DF"/>
        </Style>
        <Style Selector="Button.action:pressed">
            <Setter Property="Opacity" Value="0.8"/>
        </Style>

        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.secondary:pointerover">
            <Setter Property="Background" Value="#444444"/>
        </Style>
        <Style Selector="Button.secondary:pressed">
            <Setter Property="Opacity" Value="0.8"/>
        </Style>

        <Style Selector="Button.big">
            <Setter Property="Width" Value="240"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,10"/>
        </Style>

        <Style Selector="ListBoxItem">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="ListBoxItem:pointerover">
            <Setter Property="Background" Value="#252530"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="#2A2A35"/>
            <Setter Property="BorderBrush" Value="#2D63C8"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        
        <Style Selector="ListBox.tabs ListBoxItem">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="2,0,2,0"/>
            <Setter Property="CornerRadius" Value="6 6 0 0"/>
        </Style>
        <Style Selector="ListBox.tabs ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="#2D63C8"/>
        </Style>
        
        <Style Selector="ContextMenu">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="MenuItem:pointerover /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="#3A75DF"/>
        </Style>
    </Window.Styles>

    <Grid>
        
        <Grid x:Name="ViewStart" IsVisible="{Binding !TemProjetosAbertos}" Background="#121212">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="15">
                <TextBlock Text="Gravador MultiTrack" FontSize="36" FontWeight="Bold" Foreground="#2D63C8" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Gerenciador de Projetos" FontSize="18" Foreground="#666" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <Button Classes="big action" Click="BtnNovoProjeto_Click" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <PathIcon Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" Foreground="White" Width="18" Height="18"/>
                        <TextBlock Text="Novo Projeto" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="big secondary" Click="BtnCarregar_Click" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                        <PathIcon Data="M19,20H4C2.89,20 2,19.1 2,18V6C2,4.89 2.89,4 4,4H10L12,6H19A2,2 0 0,1 21,8H21L4,8V18L6.14,10H23.21L20.93,18.5C20.7,19.37 19.92,20 19,20Z" Foreground="White" Width="18" Height="18"/>
                        <TextBlock Text="Abrir Projeto" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Grid x:Name="ViewEditor" IsVisible="{Binding TemProjetosAbertos}" RowDefinitions="Auto, Auto, *, Auto">
            
            <Grid Grid.Row="0" Background="#0E0E0E">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal" Margin="10,10,10,0">
                        <ListBox Classes="tabs" ItemsSource="{Binding ProjetosAbertos}" SelectedItem="{Binding ProjetoSelecionado}" Background="Transparent">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Nome}" VerticalAlignment="Center" Foreground="White" FontWeight="SemiBold"/>
                                        <TextBlock Text="●" IsVisible="{Binding TemAlteracoesNaoSalvas}" Foreground="#FFA500" FontSize="10" VerticalAlignment="Center"/>
                                        <Button Click="BtnFecharAba_Click" 
                                                Background="Transparent"
                                                Padding="5,2" CornerRadius="4" BorderThickness="0">
                                            <PathIcon Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" Foreground="#888" Width="10" Height="10"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Button Click="BtnNovoProjeto_Click" Background="Transparent" Margin="5,0,0,5" VerticalAlignment="Bottom">
                            <PathIcon Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" Foreground="#666" Width="14" Height="14"/>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Border Grid.Row="1" Background="#1E1E1E" Padding="15,10">
                <Grid ColumnDefinitions="*, Auto">
                    <StackPanel Orientation="Vertical" Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ProjetoSelecionado.Nome}" FontWeight="Bold" FontSize="18" Foreground="White"/>
                        <TextBlock Text="{Binding ProjetoSelecionado.PastaRaiz}" FontSize="11" Foreground="#666"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Spacing="10" Grid.Column="1">
                        <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,20,0">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="M12,2A3,3 0 0,1 15,5V11A3,3 0 0,1 12,14A3,3 0 0,1 9,11V5A3,3 0 0,1 12,2M19,11C19,14.53 16.39,17.44 13,17.93V21H11V17.93C7.61,17.44 5,14.53 5,11H7A5,5 0 0,0 12,16A5,5 0 0,0 17,11H19Z" Foreground="#00BFFF" Width="16" Height="16" VerticalAlignment="Center"/>
                                <ComboBox ItemsSource="{Binding DispositivosEntrada}" 
                                          SelectedIndex="{Binding IndiceDispositivoSelecionado}"
                                          Width="200" Height="30" 
                                          Background="#252525" BorderThickness="0" CornerRadius="4"/>
                            </StackPanel>
                            
                            <ProgressBar Minimum="0" Maximum="1" 
                                         Value="{Binding NivelMicrofone}"
                                         Height="4" Width="225"
                                         Margin="0,5,0,0"
                                         Foreground="#00BFFF"
                                         Background="#111"
                                         CornerRadius="2"/>
                        </StackPanel>

                        <CheckBox Content="Corte Automático" 
                                  IsChecked="{Binding ProjetoSelecionado.CortarSilencioAutomaticamente}"
                                  Foreground="White" 
                                  VerticalAlignment="Center"
                                  Margin="0,0,10,0"
                                  ToolTip.Tip="Remove silêncios longos automaticamente ao finalizar uma gravação."/>

                        <Button Click="BtnSalvar_Click" Classes="action" Background="#228B22">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="M15,9H5V5H15M12,19A3,3 0 0,1 9,16A3,3 0 0,1 12,13A3,3 0 0,1 15,16A3,3 0 0,1 12,19M17,3H5C3.89,3 3,3.9 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V7L17,3Z" Foreground="White" Width="14" Height="14"/>
                                <TextBlock Text="Salvar (Ctrl+S)" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Classes="secondary">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="M5,20H19V18H5M19,9H15V3H9V9H5L12,16L19,9Z" Foreground="White" Width="14" Height="14"/>
                                <TextBlock Text="Exportar" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuItem Header="Salvar como WAV (Original)" Click="BtnExportarWav_Click"/>
                                    <MenuItem Header="Salvar como MP3" Click="BtnExportarMp3_Click"/>
                                    <MenuItem Header="Salvar como AAC / M4A" Click="BtnExportarAac_Click"/>
                                    <MenuItem Header="Salvar como FLAC (Lossless)" Click="BtnExportarFlac_Click"/>
                                    <MenuItem Header="Salvar como OGG Vorbis" Click="BtnExportarOgg_Click"/>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="20" RowDefinitions="Auto, Auto, *" DataContext="{Binding ProjetoSelecionado}">
                <TextBlock Text="Roteiro:" Foreground="#888" Margin="0,0,0,8"/>
                
                <TextBox Grid.Row="1" Height="120" TextWrapping="Wrap" 
                         AcceptsReturn="True" 
                         Watermark="Cole seu texto aqui..."
                         Background="#1E1E1E" Foreground="White" BorderThickness="0" CornerRadius="8"
                         Padding="10"
                         Text="{Binding TextoRoteiro}"/>

                <Grid Grid.Row="2" RowDefinitions="Auto, *" Margin="0,20,0,0">
                    <Button Grid.Row="0" Classes="action"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Click="BtnFatiar_Click" Margin="0,0,0,15">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="M19,3L13,9L15,11L22,4V3M12,12.5A0.5,0.5 0 0,1 11.5,12A0.5,0.5 0 0,1 12,11.5A0.5,0.5 0 0,1 12.5,12A0.5,0.5 0 0,1 12,12.5M6,20A2,2 0 0,1 4,18C4,16.89 4.9,16 6,16A2,2 0 0,1 8,18C8,19.11 7.1,20 6,20M6,8A2,2 0 0,1 4,6C4,4.89 4.9,4 6,4A2,2 0 0,1 8,6C8,7.11 7.1,8 6,8M9.64,7.64C9.87,7.14 10,6.59 10,6A4,4 0 0,0 6,2A4,4 0 0,0 2,6A4,4 0 0,0 6,10C6.59,10 7.14,9.87 7.64,9.64L10,12L7.64,14.36C7.14,14.13 6.59,14 6,14A4,4 0 0,0 2,18A4,4 0 0,0 6,22A4,4 0 0,0 10,18C10,17.41 9.87,16.86 9.64,16.36L12,14L19,21H22V20L9.64,7.64Z" Foreground="White" Width="16" Height="16"/>
                            <TextBlock Text="Fatiar Texto" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <ListBox Grid.Row="1" ItemsSource="{Binding Itens}" Background="Transparent" 
                             SelectionChanged="OnListBox_SelectionChanged"
                             x:Name="ItensListBox">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <!-- Evita overlays/bugs ao redimensionar abas em tempo real via UI virtualizada nativa -->
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:ItemRoteiro">
                                <Border Background="Transparent" Margin="0,2">
                                    
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="↑ Mover para Cima" Click="BtnMoverCima_Click" CommandParameter="{Binding}"/>
                                            <MenuItem Header="↓ Mover para Baixo" Click="BtnMoverBaixo_Click" CommandParameter="{Binding}"/>
                                            <Separator/>
                                            <MenuItem Header="✂ Modo de Corte" Click="BtnModoRecorte_Click" CommandParameter="{Binding}" IsVisible="{Binding TemAudio}"/>
                                            <MenuItem Header="✕ Excluir Frase" Click="BtnExcluirItem_Click" CommandParameter="{Binding}"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>

                                    <StackPanel Spacing="5">
                                        <Grid ColumnDefinitions="Auto, *, Auto" Tapped="OnItemTapped" Cursor="Hand" Background="Transparent">
                                            
                                            <!-- Handle de Arrastar e Soltar -->
                                            <Border Grid.Column="0" Width="30" Background="Transparent" 
                                                    Cursor="SizeAll" 
                                                    PointerPressed="OnDragHandlePointerPressed"
                                                    PointerMoved="OnDragHandlePointerMoved"
                                                    PointerReleased="OnDragHandlePointerReleased"
                                                    ToolTip.Tip="Arraste para reordenar"
                                                    VerticalAlignment="Stretch">
                                                <PathIcon Data="M7,19V17H9V19H7M11,19V17H13V19H11M15,19V17H17V19H15M7,15V13H9V15H7M11,15V13H13V15H11M15,15V13H17V15H15M7,11V9H9V11H7M11,11V9H13V11H11M15,11V9H17V11H15M7,7V5H9V7H7M11,7V5H13V7H11M15,7V5H17V7H15Z" 
                                                          Foreground="#555" Width="14" Height="14" VerticalAlignment="Center" Margin="5,0"/>
                                            </Border>

                                            <TextBlock Grid.Column="1" Text="{Binding Texto}" VerticalAlignment="Center" TextWrapping="Wrap" FontSize="15" Margin="5"/>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                                                
                                                <Button Click="BtnLimparAudio_Click" 
                                                        Background="Transparent" 
                                                        Padding="10,5"
                                                        BorderThickness="0"
                                                        IsVisible="{Binding TemAudio}"
                                                        ToolTip.Tip="Limpar Áudio (Delete)">
                                                    <PathIcon Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" Foreground="#888" Width="14" Height="14"/>
                                                </Button>

                                                <Button Click="BtnGravar_Click" Classes="secondary"
                                                        Background="{Binding IsRecording, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#FF4444:Transparent'}">
                                                    <PathIcon Data="M12,2A3,3 0 0,1 15,5V11A3,3 0 0,1 12,14A3,3 0 0,1 9,11V5A3,3 0 0,1 12,2M19,11C19,14.53 16.39,17.44 13,17.93V21H11V17.93C7.61,17.44 5,14.53 5,11H7A5,5 0 0,0 12,16A5,5 0 0,0 17,11H19Z" Foreground="White" Width="14" Height="14"/>
                                                </Button>
                                                <Button Click="BtnStop_Click" 
                                                        Classes="secondary" 
                                                        IsVisible="{Binding TemAudio}"
                                                        ToolTip.Tip="Parar e Voltar ao Início">
                                                    <PathIcon Data="M18,18H6V6H18V18Z" Foreground="White" Width="14" Height="14"/>
                                                </Button>

                                                <Button x:Name="PlayPauseButton" 
                                                        Click="BtnPlay_Click" 
                                                        Classes="secondary" 
                                                        IsEnabled="{Binding TemAudio}"
                                                        ToolTip.Tip="Reproduzir / Pausar">
                                                    <PathIcon Data="M8,5.14V19.14L19,12.14L8,5.14Z" Foreground="White" Width="14" Height="14"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>

                                        <Border Background="#101010" CornerRadius="6" Padding="10" IsVisible="{Binding IsExpanded}" Height="100">
                                            <Grid>
                                                <TextBlock Text="Sem áudio gravado" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#444" IsVisible="{Binding !TemAudio}"/>
                                                <Grid x:Name="WaveGrid" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Background="Transparent"
                                                      PointerPressed="Waveform_PointerPressed" PointerMoved="Waveform_PointerMoved" PointerReleased="Waveform_PointerReleased" IsVisible="{Binding TemAudio}">
                                                    <Border BorderBrush="#333333" BorderThickness="0,0,0,1" VerticalAlignment="Center" IsHitTestVisible="False"/>
                                                    <Polygon Points="{Binding WaveformPoints, Converter={StaticResource NullToEmptyPointsConverter}}" Fill="#00BFFF" Stretch="Fill" Opacity="0.8" IsHitTestVisible="False"/>
                                                    <Canvas HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                                        <!-- Área Selecionada em Destaque -->
                                                        <Border Background="#44FF8C00" IsVisible="{Binding IsCroppingMode}" IsHitTestVisible="False" Height="80">
                                                            <Canvas.Left>
                                                                <MultiBinding Converter="{StaticResource ProgressToPixelConverter}">
                                                                    <Binding Path="SelectionStartProgress"/>
                                                                    <Binding ElementName="WaveGrid" Path="Bounds.Width"/>
                                                                </MultiBinding>
                                                            </Canvas.Left>
                                                            <Border.Width>
                                                                <MultiBinding Converter="{StaticResource ProgressToPixelConverter}">
                                                                    <Binding Path="SelectionEndProgress" />
                                                                    <Binding ElementName="WaveGrid" Path="Bounds.Width"/>
                                                                    <Binding Path="SelectionStartProgress" />
                                                                </MultiBinding>
                                                            </Border.Width>
                                                        </Border>
                                                        
                                                        <!-- Área escura fora da seleção (Esquerda) -->
                                                        <Border Background="#66000000" IsVisible="{Binding IsCroppingMode}" IsHitTestVisible="False" Height="80" HorizontalAlignment="Left">
                                                            <Border.Width>
                                                                <MultiBinding Converter="{StaticResource ProgressToPixelConverter}">
                                                                    <Binding Path="SelectionStartProgress"/>
                                                                    <Binding ElementName="WaveGrid" Path="Bounds.Width"/>
                                                                </MultiBinding>
                                                            </Border.Width>
                                                        </Border>

                                                        <!-- Área escura fora da seleção (Direita) -->
                                                        <Border Background="#66000000" IsVisible="{Binding IsCroppingMode}" IsHitTestVisible="False" Height="80" HorizontalAlignment="Right">
                                                            <Border.Width>
                                                                <MultiBinding Converter="{StaticResource InverseProgressToPixelConverter}">
                                                                    <Binding Path="SelectionEndProgress"/>
                                                                    <Binding ElementName="WaveGrid" Path="Bounds.Width"/>
                                                                </MultiBinding>
                                                            </Border.Width>
                                                        </Border>

                                                        <!-- Puxador Esquerdo -->
                                                        <Border Width="24" Height="80" Background="Transparent" IsVisible="{Binding IsCroppingMode}" IsHitTestVisible="False" Margin="-12,0,0,0">
                                                            <Canvas.Left>
                                                                <MultiBinding Converter="{StaticResource ProgressToPixelConverter}">
                                                                    <Binding Path="SelectionStartProgress"/>
                                                                    <Binding ElementName="WaveGrid" Path="Bounds.Width"/>
                                                                </MultiBinding>
                                                            </Canvas.Left>
                                                            <Border Width="10" Height="40" Background="#FFA500" CornerRadius="5" HorizontalAlignment="Center" VerticalAlignment="Center" BoxShadow="0 2 5 0 #88000000">
                                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="1">
                                                                    <Border Width="1" Height="12" Background="#FFF"/>
                                                                    <Border Width="1" Height="12" Background="#FFF"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </Border>

                                                        <!-- Puxador Direito -->
                                                        <Border Width="24" Height="80" Background="Transparent" IsVisible="{Binding IsCroppingMode}" IsHitTestVisible="False" Margin="-12,0,0,0">
                                                            <Canvas.Left>
                                                                <MultiBinding Converter="{StaticResource ProgressToPixelConverter}">
                                                                    <Binding Path="SelectionEndProgress"/>
                                                                    <Binding ElementName="WaveGrid" Path="Bounds.Width"/>
                                                                </MultiBinding>
                                                            </Canvas.Left>
                                                            <Border Width="10" Height="40" Background="#FFA500" CornerRadius="5" HorizontalAlignment="Center" VerticalAlignment="Center" BoxShadow="0 2 5 0 #88000000">
                                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="1">
                                                                    <Border Width="1" Height="12" Background="#FFF"/>
                                                                    <Border Width="1" Height="12" Background="#FFF"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </Border>
                                                        <Border Width="2" Height="80" Background="#FF4444" IsVisible="{Binding TemAudio}" IsHitTestVisible="False">
                                                            <Canvas.Left>
                                                                <MultiBinding Converter="{StaticResource ProgressToPixelConverter}">
                                                                    <Binding Path="PlaybackProgress"/>
                                                                    <Binding ElementName="WaveGrid" Path="Bounds.Width"/>
                                                                </MultiBinding>
                                                            </Canvas.Left>
                                                        </Border>
                                                    </Canvas>
                                                </Grid>

                                                <!-- Overlays de Controle do Corte -->
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top" Spacing="10" IsVisible="{Binding IsCroppingMode}" Margin="0,-15,0,0">
                                                    <Button Click="BtnConfirmarCorte_Click" Background="#228B22" Foreground="White" Padding="10,5" CornerRadius="15" FontSize="12">
                                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                                            <PathIcon Data="M21,7L9,19L3.5,13.5L4.91,12.09L9,16.17L19.59,5.59L21,7Z" Foreground="White" Width="12" Height="12"/>
                                                            <TextBlock Text="Confirmar Corte" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Click="BtnCancelarCorte_Click" Background="#8B0000" Foreground="White" Padding="10,5" CornerRadius="15" FontSize="12">
                                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                                            <PathIcon Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" Foreground="White" Width="12" Height="12"/>
                                                            <TextBlock Text="Cancelar" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>

            <Border Grid.Row="3" Background="#191919" Padding="10,5">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Status:" Foreground="#666"/>
                    <TextBlock Text="{Binding ProjetoSelecionado.StatusTexto}" Margin="8,0" Foreground="#2D63C8" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="OverlayFatiar" IsVisible="False" Background="#AA000000">
            <Border Width="400" VerticalAlignment="Center" HorizontalAlignment="Center" Background="#252525" BorderBrush="#444" BorderThickness="1" CornerRadius="10" Padding="25">
                <StackPanel Spacing="20">
                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                        <PathIcon Data="M13,14H11V10H13M13,18H11V16H13M1,21H23L12,2L1,21Z" Foreground="#FFA500" Width="22" Height="22"/>
                        <TextBlock Text="Atenção" FontSize="22" FontWeight="Bold" Foreground="#DDD" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtMsgFatiar" Text="" TextWrapping="Wrap" TextAlignment="Center" Foreground="#AAA" FontSize="14"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15">
                        <Button Content="Cancelar" Click="BtnCancelarFatia_Click" Classes="secondary"/>
                        <Button Content="Confirmar e Apagar" Click="BtnConfirmarFatia_Click" Classes="action" Background="#444"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="OverlayFechar" IsVisible="False" Background="#AA000000">
            <Border Width="450" VerticalAlignment="Center" HorizontalAlignment="Center" Background="#252525" BorderBrush="#444" BorderThickness="1" CornerRadius="10" Padding="25">
                <StackPanel Spacing="20">
                    <TextBlock Text="Salvar alterações?" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="Você tem alterações não salvas neste projeto." TextAlignment="Center" Foreground="#AAA"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15">
                        <Button Click="BtnSalvarFechar_Click" Classes="action" Background="#228B22">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="M15,9H5V5H15M12,19A3,3 0 0,1 9,16A3,3 0 0,1 12,13A3,3 0 0,1 15,16A3,3 0 0,1 12,19M17,3H5C3.89,3 3,3.9 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V7L17,3Z" Foreground="White" Width="14" Height="14"/>
                                <TextBlock Text="Salvar e Sair" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Content="Sair sem Salvar" Click="BtnNaoSalvarFechar_Click" Classes="secondary"/>
                        <Button Content="Cancelar" Click="BtnCancelarFechar_Click" Background="Transparent" Foreground="#888"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Drag & Drop Visual Feedback -->
        <Canvas x:Name="DragOverlayCanvas" IsVisible="False" IsHitTestVisible="False">
            <Border x:Name="DragGhost" 
                    Background="#EE1E1E2E" 
                    BorderBrush="#2D63C8" 
                    BorderThickness="2" 
                    CornerRadius="8" 
                    Padding="15,10"
                    BoxShadow="0 4 16 0 #88000000">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <PathIcon Data="M7,19V17H9V19H7M11,19V17H13V19H11M15,19V17H17V19H15M7,15V13H9V15H7M11,15V13H13V15H11M15,15V13H17V15H15M7,11V9H9V11H7M11,11V9H13V11H11M15,11V9H17V11H15M7,7V5H9V7H7M11,7V5H13V7H11M15,7V5H17V7H15Z" 
                              Foreground="#2D63C8" Width="14" Height="14"/>
                    <TextBlock x:Name="DragGhostText" 
                               Foreground="#E0E0E0" 
                               FontSize="14" 
                               MaxWidth="400" 
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>
            <Border x:Name="DropIndicatorLine" 
                    Background="#2D63C8" 
                    Height="3" 
                    CornerRadius="2" 
                    IsVisible="False"/>
        </Canvas>

    </Grid>
</Window>